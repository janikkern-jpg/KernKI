# === AI Provider Keys (NIEMALS committen!) ===
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# === Datenbank ===
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/kernki?schema=public

# === NextAuth (Auth v4) ===
# Secret generieren (Windows PowerShell):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=change-me-generate-a-random-32-byte-base64-string
NEXTAUTH_URL=http://localhost:3000

# === Initialer User (nur für 'npm run seed') ===
SEED_EMAIL=du@example.com
SEED_PASSWORD=change-me-min-8-chars
