# === AI Provider Keys (NIEMALS committen!) ===
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# === Datenbank ===
# Lokal (Docker): postgresql://user:password@localhost:5432/kernki?schema=public
# Netlify/Supabase: Pooler-URL (Port 6543) + ?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://user:password@localhost:5432/kernki?schema=public

# === Login (Single-User) ===
# Hash erzeugen:
#   node scripts/hash-password.mjs "DEIN_PASSWORT"
# Session-Secret erzeugen:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_USER_EMAIL=du@example.com
APP_USER_PASSWORD_HASH=<salt-hex>:<hash-hex>
APP_SESSION_SECRET=<base64-32-bytes>
